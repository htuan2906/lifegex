# === LifeGex Environment Variables ===
# Copy to .env and fill in values

# For machine translation fallback (task 34)
VITE_TRANSLATION_API_KEY=
VITE_TRANSLATION_API_URL=https://api.example.com/translate

# For real-time metrics / WebSocket (task 42)
VITE_WS_URL=wss://api.lifegex.com/metrics

# For image optimization CDN (task 5)
VITE_IMAGE_CDN_URL=https://images.lifegex.com

# For analytics
VITE_ANALYTICS_ID=

# For contact form endpoint
VITE_CONTACT_API=https://api.lifegex.com/contact
